# ResearchOps Studio
# Safe example values only. Fill in secrets locally.

# Core app
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/researchops
WORKER_POLL_SECONDS=1.0
GIT_SHA=

# API and frontend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=/api

# Auth
AUTH_REQUIRED=true
DEV_BYPASS_AUTH=false
AUTH_JWT_SECRET=replace-with-a-local-dev-secret
AUTH_JWT_ISSUER=researchops-api
AUTH_ACCESS_TOKEN_MINUTES=30
AUTH_REFRESH_TOKEN_DAYS=14
AUTH_REFRESH_TOKEN_SECRET=
AUTH_REFRESH_COOKIE_NAME=researchops_refresh
AUTH_REFRESH_COOKIE_SECURE=false
# lax | strict | none
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_CLOCK_SKEW_SECONDS=60
AUTH_ALLOW_REGISTER=true

# Password reset
AUTH_PASSWORD_RESET_MINUTES=30
AUTH_PASSWORD_RESET_SECRET=

# MFA / TOTP
AUTH_MFA_CHALLENGE_MINUTES=5
AUTH_MFA_TOTP_ISSUER=ResearchOps Studio
AUTH_MFA_TOTP_PERIOD_SECONDS=30
AUTH_MFA_TOTP_DIGITS=6
AUTH_MFA_TOTP_WINDOW=1

# LLM provider
# hosted | bedrock | ollama
LLM_PROVIDER=

# Hosted / OpenAI-compatible LLM
HOSTED_LLM_BASE_URL=
HOSTED_LLM_API_KEY=
HOSTED_LLM_MODEL=

# AWS Bedrock LLM
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL=amazon.nova-lite-v1:0

# Model tiers
LLM_MODEL_CAPABLE=
LLM_MODEL_CHEAP=

# Per-stage overrides
# Valid stages: RETRIEVE, OUTLINE, DRAFT, EVALUATE, REPAIR, FACTCHECK, EXPORT
# Example:
# LLM_PROVIDER_DRAFT=bedrock
# LLM_MODEL_DRAFT=amazon.nova-lite-v1:0
# LLM_TIMEOUT_SECONDS_DRAFT=300

# LLM timing and JSON handling
LLM_TIMEOUT_SECONDS=180
LLM_LOG_FULL=false
LLM_JSON_REPAIR=false
LLM_JSON_REPAIR_MAX_CHARS=
LLM_JSON_REPAIR_TEMPERATURE=
LLM_USE_JSON_SCHEMA=false

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Chat search / web search
TAVILY_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CHAT_SEARCH_MODEL=

# Scientific Papers MCP
# Sources: openalex, arxiv, europepmc, core
SCIENTIFIC_PAPERS_MCP_SOURCES=openalex,arxiv,europepmc,core
SCIENTIFIC_PAPERS_MCP_COMMAND=
SCIENTIFIC_PAPERS_MCP_FALLBACK_TEXT_MAX_CHARS=200000

# Embeddings
# Explicit only. Set EMBED_PROVIDER when you want a remote provider.
# local | ollama | hosted | bedrock
EMBED_PROVIDER=
EMBED_MODEL=
EMBED_DEVICE=cpu
EMBED_DTYPE=
EMBED_NORMALIZE=
EMBED_TRUST_REMOTE_CODE=false
EMBED_MAX_SEQ_LEN=
EMBED_TEXT_MAX_CHARS=
EMBED_WORKERS=3

# AWS Bedrock embeddings
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBED_BATCH_SIZE=8
BEDROCK_EMBED_CONCURRENCY=4
BEDROCK_EMBED_TIMEOUT_SECONDS=60

# Hugging Face embeddings
HF_TOKEN=
HF_WAIT_FOR_MODEL=true

# Retriever
RETRIEVER_VECTOR_SEARCH=true
RETRIEVER_INCLUDE_EMBEDDINGS=true
RETRIEVER_MAX_SOURCES=
RETRIEVER_MAX_QUERIES=
RETRIEVER_MIN_QUERIES=
RETRIEVER_MAX_PER_QUERY=
RETRIEVER_MAX_KEYWORD_RESULTS=
RETRIEVER_MAX_VECTOR_RESULTS=
RETRIEVER_MAX_SNIPPETS_PER_SOURCE=

# Report export
DRAFT_INCLUDE_SUMMARY_COMMENTS=false
EXPORT_REPORT_PDF=false

# SMTP
# Leave SMTP_HOST blank to disable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_FROM_NAME=ResearchOps Studio
SMTP_FROM_EMAIL=

# Logging
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# text | json
LOG_FORMAT=text
LOG_FILE_PATH=artifacts/logs/backend.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=3
LOG_MAX_STRING=2000

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
